{
  "name": "livebox",
  "version": "1.5.1",
  "description": "LiveBox - M3U IPTV Player",
  "author": "aimen08",
  "license": "GPL-3.0",
  "main": "index.js",
  "private": false,
  "scripts": {
    "dev": "cross-env ELECTRON_DEV=1 vite & sleep 2 && cross-env ELECTRON_DEV=1 electron .",
    "start": "vite build && electron .",
    "dist": "cross-env ELECTRON_DIST=1 vite build && electron-builder --win && electron-builder --linux deb && electron-builder --linux AppImage && electron-builder --mac",
    "dist:win": "cross-env ELECTRON_DIST=1 vite build && electron-builder --win",
    "dist:linux": "cross-env ELECTRON_DIST=1 vite build && electron-builder --linux deb && electron-builder --linux AppImage",
    "dist:mac": "cross-env ELECTRON_DIST=1 vite build && electron-builder --mac"
  },
  "dependencies": {
    "hls.js": "^1.5.17",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "terser": "^5.46.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.aimen08.livebox",
    "productName": "LiveBox",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "index.js",
      "preload.js",
      "package.json",
      "!node_modules",
      "!src",
      "!**/*.map"
    ],
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "build-res/win/mpv",
          "to": "mpv"
        }
      ]
    },
    "mac": {
      "icon": "icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "icon.png"
    },
    "asarUnpack": []
  }
}
